# ==============================================================================
# Python
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/

# ==============================================================================
# Virtual Environments
# ==============================================================================
.venv/
venv/
env/

# ==============================================================================
# MLflow
# ==============================================================================
mlruns/
mlartifacts/

# ==============================================================================
# DVC
# ==============================================================================
# DVC cache (large binary objects stored locally)
.dvc/cache/
.dvc/tmp/
# Note: .dvc files and dvc.yaml/dvc.lock ARE tracked by Git

# ==============================================================================
# Generated Artifacts (reproduced by `dvc repro`)
# Raw data is Git-tracked (only ~6MB), but processed/generated outputs are not.
# ==============================================================================
data/processed/
data/features/
models/
metrics/
reports/

# ==============================================================================
# Docker
# ==============================================================================
.dockerignore

# ==============================================================================
# IDE / Editor
# ==============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ==============================================================================
# OS
# ==============================================================================
Thumbs.db
Desktop.ini

# ==============================================================================
# Environment Variables
# ==============================================================================
.env
.env.local
.env.production

# ==============================================================================
# Jupyter (if used for EDA)
# ==============================================================================
.ipynb_checkpoints/

# ==============================================================================
# DVC Remote (local remote directory, if used)
# ==============================================================================
dvc_remote/
